modules = ["python-3.11"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run First Exercise"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Math Module Exercise"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Specific Import Exercise"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Custom Module Exercise"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Import Custom Exercise"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Module Variables Exercise"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Circular Import Demo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Fixed Circular Import Demo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Best Practices Example"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Entry Point Example"

[[workflows.workflow]]
name = "Run First Exercise"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python exercises/01.1-your-first-import/app.py"

